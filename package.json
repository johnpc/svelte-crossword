{
	"name": "svelte-crossword-app",
	"version": "0.0.1",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"ios": "CAPACITOR_BUILD=1 npm run build && cap sync ios && cap open ios",
		"build-android": "CAPACITOR_BUILD=1 npm run build && cap sync android && cap open android",
		"android": "aws s3 cp s3://jpcbucket.com/smallcrosswords/smallcrosswords.keystore . && npm run build-android",
		"seed": "vite-node amplify/data/helpers/seed.ts",
		"sandbox": "ampx sandbox --outputs-out-dir ./src --profile personal --once",
		"prod-config": "ampx generate outputs --app-id d34i7evdsl4uqo --branch main --out-dir src --profile personal",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"test:crap": "vitest run --coverage && node scripts/crap-check.js",
		"test:e2e": "bddgen && playwright test",
		"prepare": "husky"
	},
	"devDependencies": {
		"@aws-amplify/backend": "^1.23.0",
		"@aws-amplify/backend-cli": "^1.8.3",
		"@aws-amplify/plugin-types": "^1.12.1",
		"@capacitor/android": "^8.4.1",
		"@capacitor/assets": "^3.0.5",
		"@capacitor/cli": "^8.4.1",
		"@eslint/js": "^10.0.1",
		"@fontsource/fira-mono": "^5.2.7",
		"@neoconfetti/svelte": "^2.2.2",
		"@playwright/test": "^1.61.0",
		"@sveltejs/adapter-auto": "^7.0.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.66.0",
		"@sveltejs/vite-plugin-svelte": "^7.1.2",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/svelte": "^5.3.1",
		"@types/eslint": "9.6.1",
		"@typescript-eslint/eslint-plugin": "^8.61.1",
		"@typescript-eslint/parser": "^8.61.1",
		"@vitest/coverage-istanbul": "^4.1.9",
		"amplify-adapter": "^1.3.0",
		"dotenv": "^17.4.2",
		"esbuild": "^0.28.1",
		"eslint": "^10.5.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.19.0",
		"globals": "^17.6.0",
		"husky": "^9.1.7",
		"jsdom": "^29.1.1",
		"lint-staged": "^17.0.7",
		"playwright-bdd": "^9.2.0",
		"prettier": "^3.8.4",
		"prettier-plugin-svelte": "^4.1.1",
		"svelte": "^5.56.3",
		"svelte-check": "^4.6.0",
		"ts-node": "^10.9.2",
		"tslib": "^2.8.1",
		"typescript": "^6.0.3",
		"typescript-eslint": "^8.61.1",
		"vite": "^8.0.16",
		"vite-node": "^6.0.0",
		"vitest": "^4.1.9"
	},
	"type": "module",
	"dependencies": {
		"@aws-sdk/client-lambda": "^3.1073.0",
		"@aws-sdk/client-s3": "^3.1073.0",
		"@capacitor/core": "^8.4.1",
		"@capacitor/haptics": "^8.0.2",
		"@capacitor/ios": "^8.4.1",
		"@event-calendar/core": "^5.7.1",
		"@zerodevx/svelte-toast": "^0.9.6",
		"aws-amplify": "^6.18.0",
		"svelte-loading-spinners": "^0.3.6",
		"svelte-persisted-store": "^0.12.0"
	},
	"lint-staged": {
		"*.ts": [
			"prettier --write",
			"eslint --cache --fix"
		],
		"*.json": "prettier --write",
		"*.yml": "prettier --write",
		"*.md": "prettier --write"
	}
}
